{
  "name": "@four-bytes/four-opencode-token-budget-guard",
  "version": "0.4.0",
  "description": "opencode plugin: pre-request token budget guard with soft/hard limits and diary stats",
  "type": "module",
  "main": "dist/four-opencode-token-budget-guard.js",
  "types": "dist/four-opencode-token-budget-guard.d.ts",
  "exports": {
    ".": {
      "import": "./dist/four-opencode-token-budget-guard.js",
      "types": "./dist/four-opencode-token-budget-guard.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/four-opencode-token-budget-guard.ts --outdir dist --target bun --format esm",
    "dev": "bun build src/four-opencode-token-budget-guard.ts --outdir dist --target bun --format esm --watch",
    "typecheck": "bunx tsc --noEmit"
  },
  "keywords": ["opencode", "plugin", "tokens", "budget", "cost"],
  "author": "Four Bytes",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/four-bytes/four-opencode-token-budget-guard.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.10"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.7.3"
  },
  "opencode": {
    "type": "plugin",
    "hooks": ["chat.message"]
  },
  "files": ["dist", "package.json", "README.md", "HISTORY.md", "LICENSE"]
}
