{
  "name": "@four-bytes/four-opencode-token-budget-guard",
  "version": "0.6.2",
  "description": "Token budget guard with soft/hard limits, policy engine, diary, compaction trigger, and token-meter TUI",
  "type": "module",
  "main": "dist/four-opencode-token-budget-guard.js",
  "types": "dist/four-opencode-token-budget-guard.d.ts",
  "exports": {
    ".": {
      "import": "./dist/four-opencode-token-budget-guard.js",
      "types": "./dist/four-opencode-token-budget-guard.d.ts"
    },
    "./server": {
      "types": "./dist/four-opencode-token-budget-guard.d.ts",
      "import": "./dist/four-opencode-token-budget-guard.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.jsx"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun build src/four-opencode-token-budget-guard.ts --outdir dist --target bun --format esm --watch",
    "typecheck": "bunx tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tokens",
    "budget",
    "cost"
  ],
  "author": "Four Bytes",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/four-bytes/four-opencode-token-budget-guard.git"
  },
  "dependencies": {
    "@four-bytes/opencode-plugin-lib": "file:../four-opencode-plugin-lib",
    "@opencode-ai/plugin": "^1.17.4",
    "@opentui/solid": "0.4.1",
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.7.3"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message"
    ]
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "HISTORY.md",
    "LICENSE"
  ]
}
